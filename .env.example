# ==============================================
# STUDY TIME OPTIMIZER - ENVIRONMENT VARIABLES
# ==============================================

# ==============================================
# BACKEND CONFIGURATION
# ==============================================

# Database Configuration
# For development (SQLite - no installation needed):
DATABASE_URL=sqlite:///./study_optimizer.db

# For production (PostgreSQL):
# DATABASE_URL=postgresql://user:password@localhost:5432/study_optimizer

# Security Keys (CHANGE THESE IN PRODUCTION!)
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Environment
ENVIRONMENT=development  # development | production | testing

# API Configuration
API_V1_PREFIX=/api/v1
BACKEND_HOST=localhost
BACKEND_PORT=5000

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# Email Configuration (for notifications - optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@studyoptimizer.com
EMAIL_ENABLED=false

# ==============================================
# FRONTEND CONFIGURATION
# ==============================================

# Backend API URL
VITE_API_URL=http://localhost:5000/api/v1

# App Configuration
VITE_APP_NAME=Study Time Optimizer
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_GAMIFICATION=true
VITE_ENABLE_POMODORO=true

# ==============================================
# ML ENGINE CONFIGURATION
# ==============================================

# Model Paths
ML_MODELS_PATH=ml-engine/saved_models

# Training Configuration
ML_MIN_SESSIONS_FOR_TRAINING=50
ML_RETRAIN_INTERVAL_DAYS=7

# Model Parameters
PRODUCTIVITY_MODEL_MAX_DEPTH=10
OPTIMAL_TIME_CLUSTERS=3

# ==============================================
# DATABASE CONFIGURATION
# ==============================================

# PostgreSQL (Production)
POSTGRES_USER=study_optimizer
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=study_optimizer
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ==============================================
# DOCKER CONFIGURATION
# ==============================================

# Container Names
COMPOSE_PROJECT_NAME=study-time-optimizer

# Ports
FRONTEND_PORT=3000
BACKEND_PORT=5000
DB_PORT=5432

# ==============================================
# LOGGING
# ==============================================

LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5
